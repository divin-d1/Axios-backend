PORT=5000
NODE_ENV=development

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/axios-recruitment

# ---------- JWT Authentication ----------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---------- Groq AI API ----------
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_OUTPUT_TOKENS=2048
GROQ_MAX_RETRIES=2

# Screening batch controls
GROQ_SCREENING_BATCH_SIZE=8
GROQ_SCREENING_BATCH_DELAY_MS=1000
GROQ_SCREENING_MAX_OUTPUT_TOKENS=1800

# Resume parsing controls
GROQ_RESUME_MAX_OUTPUT_TOKENS=1800
RESUME_PARSE_MAX_CHARS=4000

# CSV mapping controls
GROQ_CSV_MAX_OUTPUT_TOKENS=300

# Circuit breakers — when Groq rate-limits, pause that feature temporarily
GROQ_DISABLE_CSV_MAPPING=false
GROQ_CSV_RATE_LIMIT_COOLDOWN_MS=3600000

GROQ_DISABLE_RESUME_PARSING=false
GROQ_RESUME_RATE_LIMIT_COOLDOWN_MS=3600000

GROQ_DISABLE_SUMMARY=true
GROQ_SUMMARY_RATE_LIMIT_COOLDOWN_MS=3600000

# Prevent multiple screenings at once per company (Render-friendly)
SCREENING_LOCK_TTL_MS=600000

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER= 
SMTP_PASS=
EMAIL_FROM_NAME=Axios Recruitment
EMAIL_FROM_ADDRESS=

# ---------- File Upload ----------
MAX_FILE_SIZE_MB=10

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
