PORT=5000
NODE_ENV=development

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/axios-recruitment

# ---------- JWT Authentication ----------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---------- Gemini AI API ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_MAX_RETRIES=2

# Screening quota controls
# shortlist-only = Gemini evaluates only Top N (shortlistSize) candidates
# top-pool       = Gemini evaluates a larger contender pool (uses more quota)
GEMINI_SCREENING_REFINE_POOL_MODE=shortlist-only

GEMINI_AI_POOL_MULTIPLIER=2
GEMINI_AI_POOL_MIN=12
GEMINI_AI_POOL_MAX=36
GEMINI_SCREENING_BATCH_SIZE=4
GEMINI_SCREENING_BATCH_DELAY_MS=12000
GEMINI_SCREENING_MAX_OUTPUT_TOKENS=900

# Resume parsing quota controls
GEMINI_RESUME_MAX_OUTPUT_TOKENS=900
RESUME_PARSE_MAX_CHARS=8000

# CSV mapping quota controls
GEMINI_CSV_MAX_OUTPUT_TOKENS=200

# When Gemini free-tier DAILY quota is exhausted
# Avoid repeatedly attempting CSV mapping calls and fall back to local heuristics.
GEMINI_DISABLE_CSV_MAPPING=false
GEMINI_CSV_DAILY_QUOTA_COOLDOWN_MS=21600000

# Optional: disable Gemini for resumes/summaries during heavy testing
GEMINI_DISABLE_RESUME_PARSING=false
GEMINI_DISABLE_SUMMARY=true

# Circuit breakers when DAILY quota is exhausted (429 per-day)
GEMINI_RESUME_DAILY_QUOTA_COOLDOWN_MS=21600000
GEMINI_SUMMARY_DAILY_QUOTA_COOLDOWN_MS=21600000

# Prevent multiple screenings at once per company (Render-friendly)
SCREENING_LOCK_TTL_MS=600000

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER= 
SMTP_PASS=
EMAIL_FROM_NAME=Axios Recruitment
EMAIL_FROM_ADDRESS=

# ---------- File Upload ----------
MAX_FILE_SIZE_MB=10

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
