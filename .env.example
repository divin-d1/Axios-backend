PORT=5000
NODE_ENV=development

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/axios-recruitment

# ---------- JWT Authentication ----------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---------- Gemini AI API ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_MAX_RETRIES=2
GEMINI_AI_POOL_MULTIPLIER=2
GEMINI_AI_POOL_MIN=12
GEMINI_AI_POOL_MAX=36
GEMINI_SCREENING_BATCH_SIZE=8
GEMINI_SCREENING_BATCH_DELAY_MS=8000
GEMINI_SCREENING_MAX_OUTPUT_TOKENS=1800
GEMINI_RESUME_MAX_OUTPUT_TOKENS=1800
GEMINI_CSV_MAX_OUTPUT_TOKENS=300
RESUME_PARSE_MAX_CHARS=12000

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER= 
SMTP_PASS=
EMAIL_FROM_NAME=Axios Recruitment
EMAIL_FROM_ADDRESS=

# ---------- File Upload ----------
MAX_FILE_SIZE_MB=10

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
